        .faq-answer p {
            color: var(--text-body);
            line-height: 1.7;
            margin: 0;
            font-size: 0.85rem;
            font-family: var(--font-simple);
        }

        /* ========================================
   CTA SECTION
   ======================================== */

        .cta-section {
            padding: 4.5rem 5%;
            background: var(--bg-surface);
            text-align: center;
            position: relative;
            z-index: 2;
