    <!-- Hero Section - CLEAN (NO UNIVERSITY NAME BOXES) -->
    <section class="hero" itemscope itemtype="http://schema.org/LocalBusiness">
        <div class="hero-background"></div>

        <div class="hero-content">
            <h1 itemprop="name">Discover Your Academic Future with UniPick</h1>
            <div class="university-title">UniPick University Partners</div>
            <p>Connect with premier universities and shape your career with expert guidance tailored to your aspirations
            </p>
            <div class="hero-buttons">
                <button class="btn-primary" onclick="window.location.href='/quiz'"
                    style="padding: 0.8rem 1.8rem; min-width: 180px; justify-content: center;">
                    <i class="fas fa-clipboard-list"></i> Take Career Quiz
                </button>
                <button class="btn-bright-blue text-uppercase" onclick="window.location.href='/contact'"
                    style="color: #FFFFFF; border-color: #FFFFFF; padding: 0.8rem 1.8rem; min-width: 180px; justify-content: center; font-size: 0.95rem;">
                    <i class="fas fa-user-graduate"></i> Talk to Advisor
                </button>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
        <div class="stats-grid">
            <div class="stat-item">
                <div class="stat-icon"><i class="fas fa-users"></i></div>
                <div class="stat-number" data-target="500">0</div>
                <div class="stat-plus">+</div>
                <div class="stat-label">Students Placed</div>
            </div>
            <div class="stat-item">
                <div class="stat-icon"><i class="fas fa-university"></i></div>
                <div class="stat-number" data-target="150">0</div>
                <div class="stat-plus">+</div>
                <div class="stat-label">Partner Universities</div>
            </div>
            <div class="stat-item">
                <div class="stat-icon"><i class="fas fa-chart-line"></i></div>
                <div class="stat-number" data-target="95">0</div>
                <div class="stat-percent">%</div>
                <div class="stat-label">Success Rate</div>
            </div>
            <div class="stat-item">
                <div class="stat-icon"><i class="fas fa-headset"></i></div>
                <div class="stat-number-text">24/7</div>
                <div class="stat-label">Support Available</div>
            </div>
        </div>
    </section>

    <!-- Why Choose Us Section -->
    <section class="why-choose-us">
        <div class="section-header">
            <h2 class="section-title" style="font-size: 2.2rem;">Why Choose UniPick</h2>
            <p class="section-subtitle">Your trusted partner in university admissions and career success through expert
                admission guidance</p>
        </div>

        <div class="why-choose-grid">
            <div class="why-choose-item">
                <div class="why-choose-icon"><i class="fas fa-user-tie"></i></div>
                <div class="why-choose-text">
                    <h3>Expert Counselors</h3>
                    <p>Dedicated academic advisors with years of experience guiding students to their ideal
                        universities.</p>
                </div>
            </div>
            <div class="why-choose-item">
                <div class="why-choose-icon"><i class="fas fa-graduation-cap"></i></div>
                <div class="why-choose-text">
                    <h3>Verified Universities</h3>
                    <p>Access to carefully vetted institutions known for academic excellence and student success.</p>
                </div>
            </div>
            <div class="why-choose-item">
                <div class="why-choose-icon"><i class="fas fa-chart-line"></i></div>
                <div class="why-choose-text">
                    <h3>Career-Focused Approach</h3>
                    <p>Programs aligned with industry demands ensuring strong placement opportunities.</p>
                </div>
            </div>
            <div class="why-choose-item">
                <div class="why-choose-icon"><i class="fas fa-shield-alt"></i></div>
                <div class="why-choose-text">
                    <h3>Transparent Process</h3>
                    <p>Clear communication about fees, eligibility, and admission procedures with no hidden costs.</p>
                </div>
            </div>
            <div class="why-choose-item">
                <div class="why-choose-icon"><i class="fas fa-hands-helping"></i></div>
                <div class="why-choose-text">
                    <h3>End-to-End Support</h3>
                    <p>Comprehensive assistance from application to enrollment and beyond.</p>
                </div>
            </div>
            <div class="why-choose-item">
                <div class="why-choose-icon"><i class="fas fa-clock"></i></div>
                <div class="why-choose-text">
                    <h3>Timely Process</h3>
                    <p>Streamlined admission process with timely submission of all applications and documents.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Featured Universities - 3 CARDS PER SECTION ON DESKTOP -->
    <section class="featured-universities">
        <div class="section-header">
            <h2 class="section-title" style="font-size: 2.2rem;">Our Partner Universities</h2>
            <p class="section-subtitle">UniPick carefully selects partner universities to provide the best admission
                guidance for your academic journey</p>
        </div>

        <p class="featured-description">
            <!-- Text removed as per request -->
        </p>

        <div class="university-logos-container">
            <div class="university-logos-carousel" id="universityCarousel">
                <% universities.forEach(university=> { %>
                    <div class="university-logo-item"
                        onclick="window.location.href='/university/<%= university._id %>'">
                        <div class="university-card-content">
                            <span class="admission-badge">ADMISSION OPEN</span>

                            <div class="university-card-header">
                                <div class="university-text-info">
                                    <div class="university-location-text">
                                        <i class="fas fa-map-marker-alt"></i>
                                        <%= university.location || 'India' %>
                                    </div>
                                    <h3 class="university-name-large">
                                        <%= university.name %>
                                    </h3>
                                </div>

                                <div class="university-logo-box">
                                    <img src="<%= university.logo %>"
                                        alt="University Logo - <%= university.name %> - Top university for admission guidance"
                                        loading="lazy">
                                </div>
                            </div>

                            <div class="university-card-footer">
                                <div class="footer-item">
                                    <h4>Annual Tuition</h4>
                                    <p>
                                        <%= university.fees || '₹23 lakhs/year' %>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% }) %>
            </div>
        </div>

        <!-- Dots Navigation for Universities - INSIDE featured-universities section -->
        <div class="carousel-dots" id="universityDots"></div>

        <div style="text-align: center;">
            <button class="view-more-btn" onclick="window.location.href='/universities'">
                explore more <i class="fas fa-arrow-right animated-arrow"></i>
            </button>
        </div>
    </section>

    <!-- Student Success Stories - 3 CARDS PER SECTION ON DESKTOP -->
    <section id="stories" class="student-stories">
        <div class="section-header">
            <h2 class="section-title" style="font-size: 2.2rem;">Student Success Stories</h2>
            <p class="section-subtitle">Hear from students who achieved their dreams with our university admissions
                consultant services and career guidance</p>
        </div>

        <div class="stories-container">
            <div class="stories-carousel" id="testimonialsCarousel">
                <% testimonials.forEach(testimonial=> { %>
                    <div class="story-card" itemscope itemtype="http://schema.org/Review">
                        <div class="story-card-top">
                            <div class="student-info-left">
                                <!-- Rating Stars -->
                                <div class="student-rating" itemprop="reviewRating" itemscope
                                    itemtype="http://schema.org/Rating">
                                    <% for(let i=1; i <=5; i++) { %>
                                        <% if(i <=Math.floor(testimonial.rating || 5)) { %>
                                            <span class="star">★</span>
                                            <% } else if(i===Math.ceil(testimonial.rating || 5) && (testimonial.rating
                                                || 5) % 1 !==0) { %>
                                                <span class="star half">☆</span>
                                                <% } else { %>
                                                    <span class="star empty">☆</span>
                                                    <% } %>
                                                        <% } %>
                                                            <span class="rating-text">
                                                                <meta itemprop="ratingValue"
                                                                    content="<%= (testimonial.rating || 5).toFixed(1) %>">
                                                                <%= (testimonial.rating || 5).toFixed(1) %>
                                                            </span>
                                </div>

                                <!-- Student Details -->
                                <div class="student-details">
                                    <div class="student-name" itemprop="author">
                                        <%= testimonial.name %>
                                    </div>
                                    <div class="student-course">
                                        <%= testimonial.course %>
                                    </div>
                                    <div class="student-university">
                                        <%= testimonial.university %>
                                    </div>
                                </div>
                            </div>

                            <!-- Student Image -->
                            <div class="student-image">
                                <img src="<%= testimonial.image || 'https://via.placeholder.com/70' %>"
                                    alt="Student Success Story - <%= testimonial.name %> - University admissions testimonial"
                                    loading="lazy">
                            </div>
                        </div>

                        <!-- Review Text -->
                        <div class="story-card-bottom">
                            <p class="review-text" itemprop="reviewBody">"<%= testimonial.review %>"</p>
                        </div>
                    </div>
                    <% }) %>
            </div>
        </div>

        <!-- Dots Navigation for Testimonials - INSIDE student-stories section -->
        <div class="carousel-dots" id="testimonialDots"></div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
        <div class="section-header">
            <h2 class="section-title" style="font-size: 2.2rem;">Frequently Asked Questions</h2>
            <p class="section-subtitle">Find answers to common questions about our services and process</p>
        </div>

        <div class="faq-container">
            <div class="faq-item">
                <div class="faq-question" onclick="toggleFAQ(this)">
                    <h3>How does UniPick select its partner universities?</h3>
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="faq-answer">
                    <p>We conduct thorough evaluations of universities based on academic reputation, faculty quality,
                        placement records, infrastructure, and student support services. Our university admissions
                        consultants ensure only institutions meeting our rigorous standards for quality admission
                        guidance are included in our network.</p>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question" onclick="toggleFAQ(this)">
                    <h3>What services are included in your counseling?</h3>
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="faq-answer">
                    <p>Our comprehensive counseling includes career assessment, university selection guidance,
                        application assistance, documentation support, interview preparation, and post-admission
                        guidance. We provide end-to-end support throughout your admission journey.</p>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question" onclick="toggleFAQ(this)">
                    <h3>Are there any hidden fees or charges?</h3>
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="faq-answer">
                    <p>No, we believe in complete transparency. All fees and charges are clearly communicated upfront.
                        Our counseling service fee is separate from university tuition, and we'll help you understand
                        all costs involved before you commit.</p>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question" onclick="toggleFAQ(this)">
                    <h3>How long does the admission process typically take?</h3>
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="faq-answer">
                    <p>The timeline varies by university and program, but typically ranges from 2-6 weeks from
                        application submission to admission decision. We ensure all applications are submitted well
                        before deadlines to maximize your chances of acceptance.</p>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question" onclick="toggleFAQ(this)">
                    <h3>Can I apply to multiple universities through UniPick?</h3>
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="faq-answer">
                    <p>Yes, we encourage applying to multiple universities to increase your options. Our counselors will
                        help you create a strategic application plan with reach, match, and safety schools tailored to
                        your profile and preferences.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="cta-content">
            <h2>Ready to Start Your Academic Journey?</h2>
            <p>Take the first step towards your dream university with expert admission guidance from UniPick's
                university admissions consultants</p>
            <div class="cta-buttons">
                <button class="btn-primary large" onclick="window.location.href='/contact'">
                    <i class="fas fa-comments"></i> Schedule Free Consultation
                </button>
                <button class="btn-secondary large" onclick="window.location.href='/universities'">
                    <i class="fas fa-search"></i> Explore Universities
                </button>
            </div>
        </div>
    </section>

    <script>
        // Stats Counter Animation
        function animateStats() {
            const stats = document.querySelectorAll('.stat-number');
            stats.forEach(stat => {
                const target = parseInt(stat.getAttribute('data-target'));
                const duration = 2000;
                const increment = target / (duration / 16);
                let current = 0;

                const updateCounter = () => {
                    current += increment;
                    if (current < target) {
                        stat.textContent = Math.floor(current);
                        requestAnimationFrame(updateCounter);
                    } else {
                        stat.textContent = target;
                    }
                };

                updateCounter();
            });
        }

        // Trigger stats animation when section is visible
        const statsSection = document.querySelector('.stats-section');
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    animateStats();
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.5 });

        observer.observe(statsSection);

        // FAQ Toggle - FASTER TRANSITIONS
        function toggleFAQ(element) {
            const faqItem = element.parentElement;
            const isActive = faqItem.classList.contains('active');

            // Close all FAQs
            document.querySelectorAll('.faq-item').forEach(item => {
                item.classList.remove('active');
            });

            // Open clicked FAQ if it wasn't active
            if (!isActive) {
                faqItem.classList.add('active');
            }
        }

        // ========================================
        // UNIVERSITY CAROUSEL - RESPONSIVE CARDS PER SECTION
        // ========================================
        (function () {
            const universityCarousel = document.getElementById('universityCarousel');
            const universityDotsContainer = document.getElementById('universityDots');

            if (!universityCarousel || !universityDotsContainer) return;

            const universityCards = universityCarousel.querySelectorAll('.university-logo-item');
            let currentUniversitySlide = 0;
            let isDraggingUniversity = false;
            let startXUniversity = 0;
            let scrollLeftUniversity = 0;

            // Function to get cards per view based on screen size
            function getCardsPerView() {
                if (window.innerWidth <= 640) return 1;
                if (window.innerWidth <= 968) return 2;
                return 3;
            }

            // Calculate number of slides
            function getTotalSlides() {
                const cardsPerView = getCardsPerView();
                return Math.ceil(universityCards.length / cardsPerView);
            }

            // Create dots for universities
            function createDots() {
                universityDotsContainer.innerHTML = '';
                const totalSlides = getTotalSlides();

                for (let i = 0; i < totalSlides; i++) {
                    const dot = document.createElement('button');
                    dot.className = 'dot';
                    if (i === 0) dot.classList.add('active');
                    dot.setAttribute('aria-label', `Go to university slide ${i + 1}`);
                    dot.addEventListener('click', () => goToUniversitySlide(i));
                    universityDotsContainer.appendChild(dot);
                }
            }

            createDots();

            const getUniversityDots = () => universityDotsContainer.querySelectorAll('.dot');

            // Mouse drag handlers for universities
            universityCarousel.addEventListener('mousedown', (e) => {
                isDraggingUniversity = true;
                startXUniversity = e.pageX - universityCarousel.offsetLeft;
                scrollLeftUniversity = universityCarousel.scrollLeft;
                universityCarousel.classList.add('dragging');
            });

            universityCarousel.addEventListener('mouseleave', () => {
                isDraggingUniversity = false;
                universityCarousel.classList.remove('dragging');
            });

            universityCarousel.addEventListener('mouseup', () => {
                isDraggingUniversity = false;
                universityCarousel.classList.remove('dragging');
            });

            universityCarousel.addEventListener('mousemove', (e) => {
                if (!isDraggingUniversity) return;
                e.preventDefault();
                const x = e.pageX - universityCarousel.offsetLeft;
                const walk = (x - startXUniversity) * 2;
                universityCarousel.scrollLeft = scrollLeftUniversity - walk;
            });

            // Update current slide based on scroll position
            universityCarousel.addEventListener('scroll', () => {
                const cardsPerView = getCardsPerView();
                const cardWidth = universityCards[0].offsetWidth;
                const gap = 30;
                const sectionWidth = (cardWidth + gap) * cardsPerView;
                const scrollPosition = universityCarousel.scrollLeft;
                const newSlide = Math.round(scrollPosition / sectionWidth);

                if (newSlide !== currentUniversitySlide) {
                    currentUniversitySlide = newSlide;
                    updateUniversityDots();
                }
            });

            function goToUniversitySlide(index) {
                const cardsPerView = getCardsPerView();
                const cardWidth = universityCards[0].offsetWidth;
                const gap = 30;
                const sectionWidth = (cardWidth + gap) * cardsPerView;

                universityCarousel.scrollTo({
                    left: sectionWidth * index,
                    behavior: 'smooth'
                });
            }

            function updateUniversityDots() {
                const dots = getUniversityDots();
                dots.forEach((dot, index) => {
                    if (index === currentUniversitySlide) {
                        dot.classList.add('active');
                    } else {
                        dot.classList.remove('active');
                    }
                });
            }

            // Recreate dots on window resize
            let resizeTimeout;
            window.addEventListener('resize', () => {
                clearTimeout(resizeTimeout);
                resizeTimeout = setTimeout(() => {
                    createDots();
                    currentUniversitySlide = 0;
                    universityCarousel.scrollLeft = 0;
                }, 250);
            });
        })();

        // ========================================
        // TESTIMONIALS CAROUSEL - RESPONSIVE CARDS PER SECTION
        // ========================================
        (function () {
