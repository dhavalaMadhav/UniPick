            // Mouse drag handlers for testimonials
            testimonialCarousel.addEventListener('mousedown', (e) => {
                isDraggingTestimonial = true;
                startXTestimonial = e.pageX - testimonialCarousel.offsetLeft;
                scrollLeftTestimonial = testimonialCarousel.scrollLeft;
                testimonialCarousel.classList.add('dragging');
            });

            testimonialCarousel.addEventListener('mouseleave', () => {
                isDraggingTestimonial = false;
                testimonialCarousel.classList.remove('dragging');
            });

            testimonialCarousel.addEventListener('mouseup', () => {
                isDraggingTestimonial = false;
                testimonialCarousel.classList.remove('dragging');
            });

            testimonialCarousel.addEventListener('mousemove', (e) => {
                if (!isDraggingTestimonial) return;
                e.preventDefault();
                const x = e.pageX - testimonialCarousel.offsetLeft;
                const walk = (x - startXTestimonial) * 2;
                testimonialCarousel.scrollLeft = scrollLeftTestimonial - walk;
            });

            // Update current slide based on scroll position
            testimonialCarousel.addEventListener('scroll', () => {
                const cardsPerView = getCardsPerView();
                const cardWidth = testimonialCards[0].offsetWidth;
                const gap = 30;
                const sectionWidth = (cardWidth + gap) * cardsPerView;
                const scrollPosition = testimonialCarousel.scrollLeft;
                const newSlide = Math.round(scrollPosition / sectionWidth);

                if (newSlide !== currentTestimonialSlide) {
                    currentTestimonialSlide = newSlide;
                    updateTestimonialDots();
                }
            });

            function goToTestimonialSlide(index) {
                const cardsPerView = getCardsPerView();
                const cardWidth = testimonialCards[0].offsetWidth;
                const gap = 30;
                const sectionWidth = (cardWidth + gap) * cardsPerView;

                testimonialCarousel.scrollTo({
                    left: sectionWidth * index,
                    behavior: 'smooth'
                });
            }

            function updateTestimonialDots() {
                const dots = getTestimonialDots();
                dots.forEach((dot, index) => {
                    if (index === currentTestimonialSlide) {
                        dot.classList.add('active');
                    } else {
                        dot.classList.remove('active');
                    }
                });
            }

            // Recreate dots on window resize
            let resizeTimeout;
            window.addEventListener('resize', () => {
                clearTimeout(resizeTimeout);
                resizeTimeout = setTimeout(() => {
                    createDots();
                    currentTestimonialSlide = 0;
                    testimonialCarousel.scrollLeft = 0;
                }, 250);
            });
        })();
    </script>

